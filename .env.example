# Meshtastic Quiz — configuration. Copy to .env and fill in YOUR values.
# .env is gitignored. NEVER commit real tokens/hosts.

# --- MeshMonitor connection ---
# URL of your MeshMonitor instance's API (no trailing slash).
# On the same docker network this is typically http://meshmonitor:3001
MESHMONITOR_URL=http://your-meshmonitor-host:3001
# A MeshMonitor API token with at least: channel_<N>:write and messages:read.
# Create one in MeshMonitor: Settings -> API Tokens.
MESHMONITOR_API_TOKEN=mm_v1_replace_me
# Optional: explicit source id for multi-source MeshMonitor. Leave blank to auto-use the
# primary source.
MESHMONITOR_SOURCE_ID=

# --- Channel ---
# The channel INDEX the game runs on (the trivia channel). All game commands work here.
TRIVIA_CHANNEL_INDEX=2
# The PRIMARY channel index. The bot also listens here, but ONLY for the `!trivia` advert
# command (it replies with an invite + the channel-add link). No other command works here.
PRIMARY_CHANNEL_INDEX=0
# The Meshtastic channel-add deep link the `!trivia` advert hands out. This is PUBLIC and
# safe to commit. Replace with your own trivia channel's add link.
TRIVIA_ADD_LINK=https://meshtastic.org/e/?add=true#CgsSATEaBnRyaXZpYRIYCAEY-gEgCygFOAFAB0gBUB5YFGgByAYB

# --- Identity ---
# Your bot node's hex id (the node MeshMonitor is connected to), so the bot ignores its
# own reactions. Optional but recommended. Example form: !a1b2c3d4
BOT_NODE_ID=

# Let the HOST node also play. When true, a HUMAN tapback/typed answer originating from
# the host node (BOT_NODE_ID) is counted as a normal player answer, so whoever operates
# the host node can both launch AND play. The bot PROCESS never auto-answers (it only
# sends questions/flavor, never reactions), so this can't be used to cheat. Default false.
HOST_CAN_PLAY=false

# --- Game timing (seconds) ---
QUESTION_WINDOW_S=90
INTER_QUESTION_GAP_S=8
POLL_INTERVAL_S=4
MIN_SEND_INTERVAL_S=2

# --- Scoring ---
BASE_POINTS=10
MAX_SPEED_BONUS=5
FIRST_CORRECT_BONUS=3

# --- Anti-runup guard ---
# Auto-stop if distinct answering players <= RUNUP_MIN_PLAYERS for RUNUP_MAX_LOW_ROUNDS
# questions in a row. Default: stop when <=1 player answers for 3 rounds.
RUNUP_MIN_PLAYERS=1
RUNUP_MAX_LOW_ROUNDS=3

# --- Questions / leaderboard ---
QUESTIONS_PER_GAME=12
LEADERBOARD_TOP_N=5

# --- Answering ---
# Accept typed "1".."4" replies in-channel as a fallback for clients that can't send
# emoji reactions. Set to false for tapback-only.
ALLOW_TYPED_ANSWERS=true

# --- Mesh limits ---
MAX_PAYLOAD_BYTES=200

# --- Paths (inside the container/runtime) ---
QUESTIONS_PATH=meshquiz/data/questions.json
STATE_PATH=data/state.json

# --- Logging ---
LOG_LEVEL=INFO
